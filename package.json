{
  "name": "kiddo-sdui-homepage",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start --offline --clear",
    "start:tunnel": "expo start --tunnel --clear",
    "start:web": "expo start --web --offline --port 8081",
    "start:hotspot": "set REACT_NATIVE_PACKAGER_HOSTNAME=192.168.1.17&& expo start --offline --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@lottiefiles/dotlottie-react": "^0.6.5",
    "@shopify/flash-list": "1.7.3",
    "expo": "~52.0.46",
    "expo-asset": "~11.0.5",
    "expo-image": "~2.0.7",
    "expo-status-bar": "~2.0.1",
    "lottie-react-native": "7.2.2",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-web": "^0.19.13",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~18.3.12",
    "typescript": "^5.3.3"
  },
